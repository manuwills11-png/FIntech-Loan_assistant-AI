# ──────────────────────────────────────────────
# FinEdge Loan – Backend Environment Configuration
# Copy this file to .env and fill in your keys
# ──────────────────────────────────────────────

# App
APP_ENV=development
APP_SECRET_KEY=your-secret-key-here

# CORS – comma-separated list of allowed frontend origins
# Use * to allow all (default). In production, set to your Vercel URL:
# ALLOWED_ORIGINS=https://your-app.vercel.app
ALLOWED_ORIGINS=*

# Groq (recommended – free tier, very fast, uses Llama 3)
# Get key: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama3-groq-70b-8192-tool-use-preview

# Google Gemini (OCR Vision + chat fallback)
# Get key: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=AIza...

# OpenAI (fallback if neither Groq nor Gemini is set)
OPENAI_API_KEY=sk-...

# WhatsApp – Meta Business API (optional)
WHATSAPP_ACCESS_TOKEN=your_meta_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Twilio WhatsApp (optional – alternative to Meta API)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ML Model
MODEL_PATH=./ml/loan_risk_model.pkl

# Scheduler
SCHEDULER_TIMEZONE=Asia/Kolkata
