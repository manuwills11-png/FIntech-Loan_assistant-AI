# ──────────────────────────────────────────────
# FinEdge Loan – Environment Configuration
# Copy this file to .env and fill in your keys
# ──────────────────────────────────────────────

# App
APP_ENV=development
APP_SECRET_KEY=your-secret-key-here

# Google Cloud (set path to your service account JSON)
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

# Groq (recommended – free tier, very fast, uses Llama 3)
# Get key: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (fallback if Groq not set)
# Get key: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=AIza...

# OpenAI (fallback if neither Groq nor Gemini is set)
OPENAI_API_KEY=sk-...

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ML Model
MODEL_PATH=./ml/loan_risk_model.pkl

# Scheduler
SCHEDULER_TIMEZONE=Asia/Kolkata
